# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - only track base structure and specific CLAUDE.md files
groups/*
!groups/main/
!groups/global/
groups/main/*
groups/global/*
!groups/main/CLAUDE.md
!groups/global/CLAUDE.md

# Secrets — never commit real env or key material; .env.example is the template
*.keys.json
.env
.env.*
!.env.example

# Certs / private keys
*.pem
*.key

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
.worktrees/
.gstack/

# Claude Code local-only state (per-developer overrides; never tracked)
.claude/settings.local.json
.claude/.notify-state/
.claude/scheduled_tasks.lock
.claude/session-color
.claude-return-prompt.md
